{
  "name": "@just-agent/preview-core",
  "version": "0.4.1",
  "description": "Shared core utilities for Just-Preview.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../scripts/run-node-tests.mjs dist",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "playwright": "1.60.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/Just-Agent/Just-Product-Preview#readme",
  "bugs": {
    "url": "https://github.com/Just-Agent/Just-Product-Preview/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Just-Agent/Just-Product-Preview.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "just-preview",
    "preview",
    "agent-native",
    "monorepo",
    "playwright",
    "html2video",
    "html2thumbnail",
    "core"
  ]
}
